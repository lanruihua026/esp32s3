#ifndef _SECRETS_H_
#define _SECRETS_H_

// ==================== 敏感配置模板 ====================
// 复制本文件并重命名为 secrets.h，填写真实值后烧录。
// secrets.h 已加入 .gitignore，不会进入版本库。

// ----- WiFi 配置 -----
#define WIFI_SSID     "your_wifi_ssid"
#define WIFI_PASSWORD "your_wifi_password"

// ----- OneNET 云平台设备凭据 -----
// 在 OneNET 控制台「设备管理 → 设备详情」中获取。
// tokenExpireAt：Unix 秒级时间戳（如 2030-01-01 = 1893456000）。
#define ONENET_PRODUCT_ID      "your_product_id"
#define ONENET_DEVICE_NAME     "your_device_name"
#define ONENET_BASE64_KEY      "your_base64_key"
#define ONENET_TOKEN_EXPIRE_AT 1893456000UL

#endif
